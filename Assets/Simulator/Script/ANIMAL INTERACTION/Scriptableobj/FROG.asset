  m_Script: {fileID: 11500000, guid: 6b4014d3e56243a41a923f8562e875b0, type: 3}
  m_Name: FROG
  m_EditorClassIdentifier: 
  organismName: FROG
  nameAudioClip: {fileID: 8300000, guid: 6774f135e85332f44ada12219af41a66, type: 3}
  exploreClickAudioClip: {fileID: 8300000, guid: 630e2a5669196ab45acccd156b001a2b, type: 3}
  stages:
  - stageText: "The life cycle of a frog begins when the female frog lays eggs in
      water. Tiny tadpoles hatch from them.\r"
    stageAudioClip: {fileID: 8300000, guid: 72b8b5fbd8856f94692d669e79906f79, type: 3}
    progressionObjectName: 
  - stageText: A tadpole swims with a tail and breathes with gills.
    stageAudioClip: {fileID: 8300000, guid: 7e43a41612d7d4c4791e14c190c1b91e, type: 3}
    progressionObjectName: 
  - stageText: As tadpole grows, it develops legs and lungs, preparing for life on
      land.
    stageAudioClip: {fileID: 8300000, guid: 31cdd97345f0400438d22dfffa444ead, type: 3}
    progressionObjectName: 
  - stageText: "The tadpole becomes a froglet. It can now live both in water and
      on land.\r"
    stageAudioClip: {fileID: 8300000, guid: da0d44d789226144b868fb275495a131, type: 3}
    progressionObjectName: 
  - stageText: The froglet grows into an adult frog. Adult frogs can live for up
      to 10 years or more. The female lays eggs again and the life cycle starts over.
    stageAudioClip: {fileID: 8300000, guid: 1e3d94262c3475347a50cfb646b24159, type: 3}
    progressionObjectName: 
  progressionObjectName: 
